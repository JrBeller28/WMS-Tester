{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory item in the warehouse",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "category": { "type": "string", "description": "Product category" },
        "quantity": { "type": "number", "description": "Current stock quantity" },
        "minStockLevel": { "type": "number", "description": "Threshold for low stock alert" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., pcs, kg)" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "updatedBy": { "type": "string", "description": "User ID who last updated" }
      },
      "required": ["name", "sku", "quantity", "minStockLevel"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Record of stock entering or leaving the warehouse",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product" },
        "type": { "type": "string", "enum": ["IN", "OUT"], "description": "Type of movement" },
        "quantity": { "type": "number", "description": "Quantity moved" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the movement occurred" },
        "userId": { "type": "string", "description": "User ID who performed the movement" },
        "notes": { "type": "string", "description": "Optional notes" }
      },
      "required": ["productId", "type", "quantity", "timestamp", "userId"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "staff"], "description": "User role" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of inventory products"
    },
    "/movements/{movementId}": {
      "schema": "StockMovement",
      "description": "History of stock movements"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
